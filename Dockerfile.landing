FROM nginx:alpine
COPY landing/ /usr/share/nginx/html/landing/
COPY landing/index.html /usr/share/nginx/html/index.html
COPY blog/ /usr/share/nginx/html/blog/
COPY reports/agent-threat-report.html /usr/share/nginx/html/reports/agent-threat-report.html
COPY nginx-landing.conf /etc/nginx/conf.d/default.conf
