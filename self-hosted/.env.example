# AgentGuard Self-Hosted Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── License ──────────────────────────────────────────────────────────────────
# Your AgentGuard license key (optional — leave blank for Free tier)
# Free tier: 25,000 events/month, 3 agent seats
# Get a key at: https://agentguard.tech/pricing
AGENTGUARD_LICENSE_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL password — CHANGE THIS to a strong random password before deploying
PG_PASSWORD=change-me-to-a-strong-password
