{
  "name": "@the-bot-club/agentguard",
  "version": "0.10.0",
  "license": "MIT",
  "description": "AgentGuard SDK \u2014 policy engine, audit trail, kill switch, and LangChain/OpenAI integrations",
  "type": "module",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js",
      "require": "./dist/sdk/index.js",
      "default": "./dist/sdk/index.js"
    },
    "./openclaw": {
      "types": "./dist/integrations/openclaw.d.ts",
      "import": "./dist/integrations/openclaw.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "micromatch": "^4.0.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.0",
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.0.0",
    "hono": "^4.12.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "hono": "^4.0.0",
    "@hono/node-server": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "hono": { "optional": true },
    "@hono/node-server": { "optional": true }
  },
  "publishConfig": {
    "access": "public"
  }
}
