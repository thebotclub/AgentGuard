{
  "name": "@agentguard/api",
  "version": "0.1.0",
  "description": "AgentGuard Control Plane API — Hono REST API",
  "type": "module",
  "main": "./dist/index.js",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentguard/shared": "*",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "@prisma/adapter-pg": "^6.1.0",
    "@prisma/client": "^6.1.0",
    "hono": "^4.6.14",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "js-yaml": "^4.1.0",
    "micromatch": "^4.0.8",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "prisma": "^6.1.0",
    "tsx": "^4.19.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.0"
  }
}
