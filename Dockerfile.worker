# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.worker — AgentGuard BullMQ Background Workers
# Multi-stage build; shares the same compiled output as the API image
# ─────────────────────────────────────────────────────────────────────────────

# ── Stage 1: Dependencies ─────────────────────────────────────────────────
FROM node:22-alpine AS deps
WORKDIR /app
RUN apk add --no-cache python3 make g++

COPY package.json package-lock.json* ./
COPY packages/sdk/package.json ./packages/sdk/
COPY packages/shared/package.json ./packages/shared/

RUN npm install --prefer-offline

# ── Stage 2: Builder ──────────────────────────────────────────────────────
FROM deps AS builder
WORKDIR /app

COPY packages/ ./packages/
COPY api/ ./api/
COPY tsconfig.json ./

# Build SDK
RUN cd packages/sdk && npm run build 2>/dev/null || true

# Compile TypeScript
RUN cd api && npx tsc 2>/dev/null || true

# Build worker entry points if they exist in api/workers/
RUN if ls api/workers/*.ts 2>/dev/null | head -1; then \
      mkdir -p dist/workers && \
      npx esbuild $(ls api/workers/*.ts | tr '\n' ' ') \
        --bundle \
        --platform=node \
        --target=node22 \
        --format=cjs \
        --outdir=dist/workers \
        --packages=external 2>/dev/null; \
    else \
      mkdir -p dist/workers && echo "// no workers found" > dist/workers/placeholder.js; \
    fi

# ── Stage 3: Production runner ────────────────────────────────────────────
FROM node:22-alpine AS runtime
WORKDIR /app

ENV NODE_ENV=production

RUN apk add --no-cache python3 make g++ curl

# Create non-root user
RUN addgroup --system --gid 1001 nodejs \
 && adduser --system --uid 1001 --ingroup nodejs agentguard

# Install production deps only
COPY package.json package-lock.json* ./
COPY packages/sdk/package.json ./packages/sdk/
COPY packages/shared/package.json ./packages/shared/
RUN npm install --omit=dev --prefer-offline && npm cache clean --force

# Copy compiled output
COPY --from=builder --chown=agentguard:nodejs /app/dist ./dist
COPY --from=builder --chown=agentguard:nodejs /app/packages ./packages

# Copy worker startup script
COPY --chown=agentguard:nodejs docker/start-workers.sh ./start-workers.sh
RUN chmod +x ./start-workers.sh

USER agentguard

EXPOSE 3002

HEALTHCHECK --interval=30s --timeout=5s --start-period=40s --retries=3 \
  CMD node -e "fetch('http://localhost:3002/health').then(r=>r.ok?process.exit(0):process.exit(1)).catch(()=>process.exit(1))"

CMD ["./start-workers.sh"]
