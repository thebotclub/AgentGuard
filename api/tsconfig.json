{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./dist",
    "rootDir": "..",
    "resolveJsonModule": true,
    "declaration": false,
    "skipLibCheck": true
  },
  "include": ["server.ts", "schemas.ts", "validation-routes.ts", "phase2-routes.ts", "mcp-routes.ts", "mcp-middleware.ts", "db-interface.ts", "db.ts", "../src/core/**/*.ts"]
}
