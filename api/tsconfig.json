{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": true,
    "outDir": "./dist",
    "rootDir": "..",
    "resolveJsonModule": true,
    "declaration": false,
    "skipLibCheck": true
  },
  "include": ["**/*.ts", "../packages/sdk/src/core/**/*.ts"],
  "exclude": ["**/*.test.ts", "**/*.spec.ts", "../packages/**/tests/**", "../packages/**/__tests__/**"]
}
