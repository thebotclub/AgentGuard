{
  "name": "agentguard",
  "version": "0.9.0",
  "private": true,
  "description": "AgentGuard — Runtime security platform for AI agents",
  "workspaces": [
    "packages/*",
    "remotion"
  ],
  "scripts": {
    "dev": "npx tsx api/server.ts",
    "test": "npx tsx --test tests/unit.test.ts",
    "test:e2e": "npx tsx --test tests/e2e.test.ts",
    "test:all": "npx tsx --test tests/*.test.ts",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "npx eslint api/ packages/sdk/src packages/cli/src packages/shared/src --max-warnings=0",
    "lint:fix": "npx eslint api/ packages/sdk/src packages/cli/src packages/shared/src --fix",
    "typecheck": "cd api && npx tsc --noEmit",
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules",
    "docs:dev": "vitepress dev vitepress-docs",
    "docs:build": "vitepress build vitepress-docs",
    "docs:preview": "vitepress preview vitepress-docs"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.17.0",
    "eslint-plugin-security": "^3.0.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/pg": "^8.18.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jose": "^6.2.0",
    "js-yaml": "^4.1.1",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "swagger-ui-dist": "^5.32.0",
    "zod": "^4.3.6"
  }
}
