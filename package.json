{
  "name": "agentguard",
  "version": "0.8.0",
  "private": true,
  "description": "AgentGuard — Runtime security platform for AI agents",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npx tsx api/server.ts",
    "test": "npx tsx --test tests/unit.test.ts",
    "test:e2e": "npx tsx --test tests/e2e.test.ts",
    "test:all": "npx tsx --test tests/*.test.ts",
    "lint": "npx tsc --noEmit",
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@remotion/cli": "^4.0.431",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remotion": "^4.0.431",
    "swagger-ui-dist": "^5.32.0",
    "zod": "^4.3.6"
  }
}
