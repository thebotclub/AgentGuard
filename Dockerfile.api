FROM node:20-alpine
WORKDIR /app

# Install build tools needed for better-sqlite3 native module
RUN apk add --no-cache python3 make g++

COPY package.json package-lock.jso* ./
COPY packages/sdk/package.json ./packages/sdk/
COPY packages/shared/package.json ./packages/shared/

# Install dependencies — use lockfile if available, fallback to install
RUN if [ -f package-lock.json ]; then npm ci --omit=dev; else npm install express cors better-sqlite3 js-yaml zod; fi && \
    cd packages/sdk && npm install 2>/dev/null; \
    cd /app

COPY packages/ ./packages/
COPY api/ ./api/

# Create /data directory for SQLite persistence
RUN mkdir -p /data

# Declare /data as a volume so it can be mounted
VOLUME /data

EXPOSE 3000
CMD ["npx", "tsx", "api/server.ts"]
