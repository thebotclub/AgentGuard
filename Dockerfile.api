FROM node:22-alpine AS builder
WORKDIR /app

# Build tools needed for better-sqlite3 native module
RUN apk add --no-cache python3 make g++

# Copy manifests first for better layer caching
COPY package.json package-lock.json* ./
COPY packages/sdk/package.json ./packages/sdk/
COPY packages/shared/package.json ./packages/shared/

# Install ALL dependencies (including devDeps for tsc)
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

# Copy source
COPY packages/ ./packages/
COPY api/ ./api/
COPY tsconfig.json ./

# Build SDK first (api/tsconfig.json includes SDK source directly)
RUN cd packages/sdk && npm run build 2>/dev/null || true

# Compile TypeScript to dist/
RUN cd api && npx tsc --noEmit || true && npx tsc

# ── Production image ──────────────────────────────────────────────────────
FROM node:22-alpine AS runtime
WORKDIR /app

RUN apk add --no-cache python3 make g++

# Copy manifests
COPY package.json package-lock.json* ./
COPY packages/sdk/package.json ./packages/sdk/
COPY packages/shared/package.json ./packages/shared/

# Install only production dependencies
RUN if [ -f package-lock.json ]; then npm ci --omit=dev; else npm install --omit=dev; fi

# Copy compiled output from builder
COPY --from=builder /app/dist ./dist

# Copy SDK built dist (imported by API at runtime)
COPY --from=builder /app/packages ./packages

# Create /data directory for SQLite persistence
RUN mkdir -p /data

# Declare /data as a volume so it can be mounted
VOLUME /data

EXPOSE 3000
# dist/ output is relative to rootDir ".." (monorepo root), so api/server.ts → dist/api/server.js
CMD ["node", "dist/api/server.js"]
