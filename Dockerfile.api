# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.api — AgentGuard API (Hono / Express on Node.js 22 LTS)
# Multi-stage build: builder → production runtime
# ─────────────────────────────────────────────────────────────────────────────

# ── Stage 1: Dependencies ─────────────────────────────────────────────────
FROM node:22-alpine AS deps
WORKDIR /app

# Native build tools for better-sqlite3 (SQLite fallback) and bcrypt
RUN apk add --no-cache python3 make g++

# Copy manifests first for layer cache efficiency
COPY package.json package-lock.json* ./
COPY packages/sdk/package.json ./packages/sdk/
COPY packages/shared/package.json ./packages/shared/

# Install ALL deps (devDeps needed for TypeScript compilation)
# Using `install` instead of `ci` for resilience against lock file drift
RUN npm install --prefer-offline

# ── Stage 2: Builder ──────────────────────────────────────────────────────
FROM deps AS builder
WORKDIR /app

# Copy all source files
COPY packages/ ./packages/
COPY api/ ./api/
COPY tsconfig.json ./

# Build SDK package (api imports from it)
RUN cd packages/sdk && npm run build 2>/dev/null || true

# Compile API TypeScript → dist/
RUN cd api && npx tsc --noEmit 2>/dev/null | tail -5 || true
RUN cd api && npx tsc

# ── Stage 3: Production image ─────────────────────────────────────────────
FROM node:22-alpine AS runtime
WORKDIR /app

# Runtime native deps only
RUN apk add --no-cache python3 make g++ curl

# Create non-root user
RUN addgroup --system --gid 1001 nodejs \
 && adduser --system --uid 1001 --ingroup nodejs agentguard

# Copy manifests
COPY package.json package-lock.json* ./
COPY packages/sdk/package.json ./packages/sdk/
COPY packages/shared/package.json ./packages/shared/

# Install production-only deps
RUN npm install --omit=dev --prefer-offline && npm cache clean --force

# Copy compiled output from builder (tsc outputs to api/dist/ with rootDir: "..")
COPY --from=builder /app/api/dist ./dist
COPY --from=builder /app/packages ./packages

# Create /data for SQLite persistence and set ownership
RUN mkdir -p /data && chown agentguard:nodejs /data /app

VOLUME /data

# Switch to non-root
USER agentguard

EXPOSE 3000

# Liveness: GET /health returns {"status":"ok"}
HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=5 \
  CMD node -e "fetch('http://localhost:3000/health').then(r=>r.ok?process.exit(0):process.exit(1)).catch(()=>process.exit(1))"

CMD ["node", "dist/api/server.js"]
