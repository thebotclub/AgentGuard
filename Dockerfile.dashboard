# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.dashboard — AgentGuard Dashboard (Next.js 15 / React 19)
# Multi-stage build; uses Next.js standalone output for minimal image size
# ─────────────────────────────────────────────────────────────────────────────

# ── Stage 1: Dependencies ─────────────────────────────────────────────────
FROM node:22-alpine AS deps
WORKDIR /app
RUN apk add --no-cache libc6-compat

# Copy workspace manifests for dependency resolution
COPY package.json package-lock.json* ./
COPY packages/dashboard/package.json ./packages/dashboard/
COPY packages/shared/package.json ./packages/shared/

RUN npm install --prefer-offline

# ── Stage 2: Builder ──────────────────────────────────────────────────────
FROM deps AS builder
WORKDIR /app

# Copy shared package source (dashboard transpiles it)
COPY packages/shared/ ./packages/shared/
COPY packages/dashboard/ ./packages/dashboard/

# Set API URL at build time (can be overridden at runtime via env)
ARG NEXT_PUBLIC_API_URL=http://localhost:3000
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

# Inject standalone output mode into next.config.js
# Works with both ESM (export default) and CJS (module.exports) formats
RUN cd packages/dashboard && \
    if grep -q 'output.*standalone' next.config.js 2>/dev/null; then \
      echo "standalone output already configured"; \
    elif grep -q 'export default' next.config.js 2>/dev/null; then \
      sed -i 's/const nextConfig = {/const nextConfig = {\n  output: "standalone",/' next.config.js; \
    elif grep -q 'module.exports' next.config.js 2>/dev/null; then \
      sed -i 's/module.exports = {/module.exports = {\n  output: "standalone",/' next.config.js; \
    fi

WORKDIR /app/packages/dashboard

# Guarantee target directories exist so Docker COPY commands in stage 3 don't crash
RUN mkdir -p /app/packages/dashboard/node_modules \
             /app/packages/dashboard/.next/standalone \
             /app/packages/dashboard/.next/static \
             /app/packages/dashboard/public

# Build Next.js application
RUN npm run build

# ── Stage 3: Production runner ────────────────────────────────────────────
FROM node:22-alpine AS runtime
WORKDIR /app

RUN apk add --no-cache curl

# Create non-root user
RUN addgroup --system --gid 1001 nodejs \
 && adduser --system --uid 1001 --ingroup nodejs nextjs

# Try standalone output first (smaller image), fall back to full .next
COPY --from=builder --chown=nextjs:nodejs /app/packages/dashboard/package.json ./
COPY --from=builder --chown=nextjs:nodejs /app/packages/dashboard/node_modules ./node_modules

# Copy standalone build if it exists (preferred)
RUN mkdir -p .next
COPY --from=builder --chown=nextjs:nodejs /app/packages/dashboard/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/packages/dashboard/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/packages/dashboard/.next ./.next
COPY --from=builder --chown=nextjs:nodejs /app/packages/dashboard/public ./public

USER nextjs

EXPOSE 3001

ENV PORT=3001
ENV HOSTNAME="0.0.0.0"
ENV NODE_ENV=production

HEALTHCHECK --interval=20s --timeout=5s --start-period=60s --retries=5 \
  CMD node -e "fetch('http://localhost:3001').then(r=>process.exit(0)).catch(()=>process.exit(1))"

# Use standalone server.js if present, otherwise fall back to next start
CMD if [ -f "server.js" ]; then node server.js; else npx next start -p 3001; fi
