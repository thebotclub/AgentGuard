# ─────────────────────────────────────────────────────────────────────────────
# AgentGuard — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Quick start:
#   cp .env.example .env
#   bash scripts/self-hosted-setup.sh   # auto-generates secrets + runs migrations
#
# Or manually fill in the required values (marked REQUIRED) below.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info                    # debug | info | warn | error

# ── Server Ports ──────────────────────────────────────────────────────────────
API_PORT=3000                     # AgentGuard API (Hono/Express)
DASHBOARD_PORT=3001               # Next.js dashboard

# ── REQUIRED: Security Secrets ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# These MUST be set to strong random values in production.
# The API will refuse to start if these are missing or look like dev values.

JWT_SECRET=                       # REQUIRED — min 32 chars, no 'dev-' prefix
INTEGRATION_ENCRYPTION_KEY=       # REQUIRED — 64 hex chars (32 bytes AES-256-GCM)
ADMIN_KEY=                        # REQUIRED — admin API key for /v1/admin/* endpoints

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (used when DB_TYPE=postgres, which is default in Docker Compose)
POSTGRES_PASSWORD=                # REQUIRED — strong random password for Postgres

# DB_TYPE controls which backend to use:
#   postgres  — PostgreSQL (recommended for production)
#   sqlite    — SQLite file at DB_PATH (development only)
DB_TYPE=postgres

# SQLite settings (only used when DB_TYPE=sqlite)
# DB_PATH=./agentguard.db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis URL is auto-configured in Docker Compose.
# Override here if using an external Redis instance:
# REDIS_URL=redis://:password@your-redis-host:6379

# ── Dashboard (Next.js) ───────────────────────────────────────────────────────
# URL the browser uses to reach the API (public-facing)
NEXT_PUBLIC_API_URL=http://localhost:3000

# NextAuth.js configuration (for dashboard auth)
NEXTAUTH_URL=http://localhost:3001

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MIN=100            # API requests per minute per IP
SIGNUP_RATE_LIMIT_PER_HOUR=5     # Account creation rate limit

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (beyond agentguard.tech subdomains)
# Example: CORS_ORIGINS=https://myapp.example.com,https://staging.myapp.com
# CORS_ORIGINS=

# ── SSO / JWT Verification ────────────────────────────────────────────────────
# For enterprise SSO (SAML/OIDC), configure your IdP JWKS endpoint.
# JWT_JWKS_URL=https://your-idp.example.com/.well-known/jwks.json
# JWT_AUDIENCE=agentguard-api
# JWT_ISSUER=https://your-idp.example.com

# ── Slack HITL Integration ────────────────────────────────────────────────────
# Required for Human-in-the-Loop approval via Slack.
# See: https://docs.agentguard.tech/integrations/slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_CHANNEL_ID=C0XXXXXXXXX

# ── License ───────────────────────────────────────────────────────────────────
# Free tier: 100,000 events/month, 3 agent seats — no key needed.
# Get a Pro/Enterprise key at: https://agentguard.tech/pricing
# AGENTGUARD_LICENSE_KEY=AGKEY-...

# ── Stripe Billing (optional — only for AgentGuard Cloud) ────────────────────
# Self-hosted customers do not need Stripe credentials.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Telemetry ─────────────────────────────────────────────────────────────────
# Set to 1 to disable anonymous usage telemetry (SDK pings)
# AGENTGUARD_NO_TELEMETRY=1
