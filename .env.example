# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection URL (via PgBouncer in production)
DATABASE_URL="postgresql://agentguard:password@localhost:5432/agentguard?schema=public"
# Direct URL for Prisma Migrate (bypasses PgBouncer in transaction mode)
DATABASE_DIRECT_URL="postgresql://agentguard:password@localhost:5432/agentguard?schema=public"

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection URL (ElastiCache Sentinel in production)
REDIS_URL="redis://localhost:6379"

# ─── Auth ──────────────────────────────────────────────────────────────────────
# JWT secret for signing tokens (use RS256 keypair in production)
JWT_SECRET="change-me-in-production-use-at-least-32-chars"
# JWT algorithm: HS256 (dev) or RS256 (production)
JWT_ALGORITHM="HS256"
# JWT expiry
JWT_EXPIRY="1h"

# ─── API ───────────────────────────────────────────────────────────────────────
# API server port
PORT="8080"
# Base URL for the API (used in SDK bundle URLs)
API_BASE_URL="http://localhost:8080"
# Service name for logging and tracing
SERVICE_NAME="agentguard-api"
# Environment: development | staging | production
NODE_ENV="development"

# ─── AWS (production) ──────────────────────────────────────────────────────────
# AWS region for data residency
AWS_REGION="us-east-1"
# S3 bucket for forensic blobs, policy exports, compliance evidence
S3_BUCKET="agentguard-data"
# AWS Secrets Manager prefix
SECRETS_PREFIX="agentguard/production"

# ─── Observability ─────────────────────────────────────────────────────────────
# Datadog API key (OpenTelemetry traces + metrics)
DATADOG_API_KEY=""
# Log level: debug | info | warn | error
LOG_LEVEL="info"

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# Global API rate limit per IP (requests per minute)
RATE_LIMIT_GLOBAL_RPM="600"
# Per-tenant API rate limit (requests per minute)
RATE_LIMIT_TENANT_RPM="120"

# ─── Dashboard ─────────────────────────────────────────────────────────────────
# Next.js public API URL (for client-side fetches)
NEXT_PUBLIC_API_URL="http://localhost:8080"
# NextAuth secret
NEXTAUTH_SECRET="change-me-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── Worker ────────────────────────────────────────────────────────────────────
# BullMQ concurrency for SIEM push worker
SIEM_WORKER_CONCURRENCY="5"
# Telemetry ingest worker concurrency
TELEMETRY_WORKER_CONCURRENCY="10"
