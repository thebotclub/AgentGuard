# ─────────────────────────────────────────────────────────────────────────────
# AgentGuard — Environment Variables
# Copy this file to .env and fill in the values for your deployment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── Auth ─────────────────────────────────────────────────────────────────────
# Master admin key for /api/v1/admin/* endpoints (change in production!)
ADMIN_KEY=ag_admin_your_key_here

# ── Database ─────────────────────────────────────────────────────────────────
# DB_TYPE: "sqlite" (default, dev) or "postgres" (production)
DB_TYPE=sqlite
DB_PATH=./agentguard.db

# PostgreSQL (required when DB_TYPE=postgres)
# DATABASE_URL=postgresql://user:password@localhost:5432/agentguard

# ── Redis (optional — falls back to in-memory rate limiting) ─────────────────
# REDIS_URL=redis://localhost:6379

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MIN=100
SIGNUP_RATE_LIMIT_PER_HOUR=5

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of additional origins (agentguard.tech subdomains are always allowed)
# CORS_ORIGINS=https://myapp.example.com

# ── JWT / SSO ────────────────────────────────────────────────────────────────
# JWKS endpoint for RS256 JWT verification (required for SSO)
# JWT_JWKS_URL=https://your-idp.example.com/.well-known/jwks.json
# JWT_AUDIENCE=agentguard-api
# JWT_ISSUER=https://your-idp.example.com

# ── Encryption (REQUIRED in production) ──────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of integration secrets (Slack, SSO)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# INTEGRATION_ENCRYPTION_KEY=your_64_char_hex_string_here

# ── Stripe / Billing ──────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Slack HITL ───────────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_CHANNEL_ID=C0XXXXXXXXX

# ── License ───────────────────────────────────────────────────────────────────
# AGENTGUARD_LICENSE_KEY=AGKEY-...

# ── SDK Telemetry ─────────────────────────────────────────────────────────────
# Set to 1 to disable SDK telemetry pings
# AGENTGUARD_NO_TELEMETRY=1
