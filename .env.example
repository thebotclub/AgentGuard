# ─────────────────────────────────────────────────────────────────────────────
# AgentGuard — Environment Variables
# Copy to .env and fill in values for local development
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
SERVICE_NAME=agentguard-api

# ── Database (PostgreSQL 16) ────────────────────────────────────────────────
DATABASE_URL=postgresql://agentguardadmin:localpassword@localhost:5432/agentguard?schema=public
DATABASE_DIRECT_URL=postgresql://agentguardadmin:localpassword@localhost:5432/agentguard?schema=public

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-64-byte-random-string-in-production
API_KEY_SALT=12

# ── Azure Blob Storage (optional for local dev) ────────────────────────────
# AZURE_STORAGE_CONNECTION_STRING=

# ── Email / HITL Notifications (optional) ───────────────────────────────────
# SES_SMTP_HOST=
# SES_SMTP_USER=
# SES_SMTP_PASS=

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3001

# ── OpenTelemetry (optional) ────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_SERVICE_NAME=agentguard-api

# ── Dashboard ──────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:3000/v1
